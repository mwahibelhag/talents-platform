run = "streamlit run main.py --server.port 8501 --server.address 0.0.0.0"
modules = ["python-3.11"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "منصة مواهب"

[[workflows.workflow]]
name = "منصة مواهب"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run main.py --server.port 8501 --server.address 0.0.0.0"
waitForPort = 8501

[workflows.workflow.metadata]
outputType = "webview"

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8501
externalPort = 80
